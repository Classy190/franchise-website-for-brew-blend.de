# Environment Variables Template
# Kopiere diese Datei zu .env und fülle deine Werte ein

# ==================== EMAIL KONFIGURATION ====================
# Gmail oder ähnlicher SMTP-Service
EMAIL_USER=deine-email@gmail.com
EMAIL_PASSWORD=dein-app-specific-password

# ==================== ADMIN EINSTELLUNGEN ====================
ADMIN_EMAIL=admin@brewblend.de
ADMIN_PHONE=+49 (0) 123 456789

# ==================== DATENBANK ====================
# MongoDB Connection String (wenn MongoDB verwendet wird)
MONGODB_URI=mongodb://username:password@localhost:27017/brew-blend

# PostgreSQL (wenn PostgreSQL verwendet wird)
DATABASE_URL=postgresql://user:password@localhost:5432/brew_blend

# ==================== SERVER ====================
NODE_ENV=development
PORT=3000
HOST=localhost

# ==================== SICHERHEIT ====================
# JWT Secret für Authentication
JWT_SECRET=your-super-secret-key-change-this

# CORS Allowed Origins
CORS_ORIGIN=http://localhost:8000,https://brewblend.de

# API Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# ==================== EXTERNE SERVICES ====================
# Google Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# SendGrid (Alternative zu Gmail)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# Stripe (für zukünftige Zahlungen)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx

# ==================== DEVELOPMENT ====================
DEBUG=true
LOG_LEVEL=debug
